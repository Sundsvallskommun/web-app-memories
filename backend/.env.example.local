# Server
PORT=3001
BASE_URL_PREFIX=/api

# API Connection (OAuth2 Client Credentials)
API_BASE_URL=https://api-test.sundsvall.se
CLIENT_KEY={{INSERT CLIENT_KEY}}
CLIENT_SECRET={{INSERT CLIENT_SECRET}}

# Municipality
MUNICIPALITY_ID=2281

# Security
SECRET_KEY=change-me-in-production

# Session
SESSION_STORE=memory

# CORS
ORIGIN=http://localhost:3000
CREDENTIALS=true

# Logging
LOG_FORMAT=dev
LOG_DIR=./data/logs
